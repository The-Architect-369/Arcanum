+"use client";
+
+import { useEffect, useState } from "react";
+import { useRouter } from "next/navigation";
+import ACCOnboardingModal from "@/components/ui/ACCOnboardingModal";
+import { completeOnboarding, getState, subscribe } from "@/state/useAccount";
+
+/**
+ * Onboarding (Vercel-first)
+ * - No Arcnet requirement yet.
+ * - Performs a "soft activation" so the experience path is usable.
+ * - Later: replace completeOnboarding() with real Arcnet ChainCode mint + receipt.
+ */
+export default function OnboardPage() {
+  const router = useRouter();
+  const [ready, setReady] = useState(false);
+  const [open, setOpen] = useState(false);
+
+  useEffect(() => {
+    const unsub = subscribe(() => {
+      const s = getState();
+      // once trusted, go straight into the app boundary
+      if (s.trusted) router.replace("/hope");
+    });
+    setReady(true);
+    // open the onboarding modal immediately
+    setOpen(true);
+    return () => unsub();
+  }, [router]);
+
+  async function softActivate() {
+    await completeOnboarding(); // sets trusted=true + starter mana stub
+    router.replace("/hope");
+  }
+
+  if (!ready) return null;
+
+  return (
+    <main className="mx-auto max-w-xl px-4 py-12 space-y-6">
+      <h1 className="text-2xl font-bold">Onboarding</h1>
+      <p className="text-sm opacity-80">
+        This is the Vercel-first experience path. Arcnet validation will be wired after the UI is stable.
+      </p>
+
+      <div className="flex flex-wrap gap-3">
+        <button
+          className="rounded-xl border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium hover:bg-white/15"
+          onClick={() => setOpen(true)}
+        >
+          Open activation
+        </button>
+        <button
+          className="rounded-xl border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium hover:bg-white/15"
+          onClick={softActivate}
+        >
+          Continue (soft activation)
+        </button>
+        <button
+          className="rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm hover:bg-white/10"
+          onClick={() => router.replace("/")}
+        >
+          Back to site
+        </button>
+      </div>
+
+      <ACCOnboardingModal open={open} onOpenChange={setOpen} />
+    </main>
+  );
+}
